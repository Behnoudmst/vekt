DATABASE_URL="file:./dev.db"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# ── Seed accounts (used by: npx tsx scripts/seed.ts) ─────────────────────────
SEED_ADMIN_EMAIL="admin@vekt.io"
SEED_ADMIN_PASSWORD=
SEED_RECRUITER_EMAIL="recruiter@vekt.io"
SEED_RECRUITER_PASSWORD=

# ── AI evaluation ─────────────────────────────────────────────────────────────
# Choices: mock (default, no API key needed) | openai | ollama
AI_PROVIDER="mock"

# Required when AI_PROVIDER=openai
OPENAI_API_KEY=

# Required when AI_PROVIDER=ollama
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# ── Inngest (durable evaluation pipeline) ────────────────────────────────────
# Leave blank in dev to use the direct in-process fallback instead.
# Sign up at https://inngest.com and set these for production / Inngest Dev Server.
INNGEST_EVENT_KEY=
# Must be an even-length hex string — generate with: openssl rand -hex 32
INNGEST_SIGNING_KEY=

# ── Branding ─────────────────────────────────────────────────────────────────
COMPANY_NAME="Vekt"

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error  (default: info)
LOG_LEVEL="info"
