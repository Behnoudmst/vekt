DATABASE_URL="file:./dev.db"
# App Url --------
APP_URL="http://localhost:3000" 
# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-change-in-production-min-32-chars"

# ── Seed accounts (used by: npx tsx scripts/seed.ts) ─────────────────────────
SEED_ADMIN_EMAIL="admin@vekt.io"
SEED_ADMIN_PASSWORD="change-me-to-a-long-random-password" # Must meet the password requirements defined in lib/schemas.ts

# ── AI evaluation ─────────────────────────────────────────────────────────────
# Choices: mock (default, no API key needed) | openai | ollama
AI_PROVIDER="mock"

# Required when AI_PROVIDER=openai
OPENAI_API_KEY=

# Required when AI_PROVIDER=ollama
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# ── Inngest (durable evaluation pipeline) ────────────────────────────────────
# Leave blank in dev to use the direct in-process fallback instead.
# Sign up at https://inngest.com and set these for production / Inngest Dev Server.
INNGEST_EVENT_KEY=
# Must be an even-length hex string — generate with: openssl rand -hex 32
INNGEST_SIGNING_KEY=

# Docker bootstrap: set to true only for the first container start when you want
# the entrypoint to run scripts/seed.ts automatically.
SEED_ON_START="false"

# ── Email (transactional — powered by Resend) ────────────────────────────────
# Sign up at https://resend.com and create an API key.
# Leave blank to disable email sending (status transitions will still work).
RESEND_API_KEY=
# Sender address — must be a verified domain in your Resend account.
EMAIL_FROM="noreply@vekt.io"
# Public base URL used to build status-page and unsubscribe links.
APP_URL="http://localhost:3000"

# ── Branding ─────────────────────────────────────────────────────────────────
COMPANY_NAME="Vekt"

# ── Logging ───────────────────────────────────────────────────────────────────
# trace | debug | info | warn | error  (default: info)
LOG_LEVEL="info"

# Email addresses
SUPPORT_EMAIL=
