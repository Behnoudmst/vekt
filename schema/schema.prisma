generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "sqlite"
}

model Job {
  id           String      @id @default(cuid())
  slug         String      @unique
  title        String
  description  String
  location     String?
  customPrompt String?
  threshold    Int         @default(75)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  candidates   Candidate[]
  views        JobView[]
  createdById  String?
  createdBy    User?       @relation(fields: [createdById], references: [id], onDelete: SetNull)
}

model JobView {
  id       String   @id @default(cuid())
  jobId    String
  job      Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  referrer String?
  viewedAt DateTime @default(now())
}

model Candidate {
  id                   String          @id @default(cuid())
  name                 String
  email                String
  resumePath           String
  resumeText           String          @default("")
  status               CandidateStatus @default(APPLIED)
  appliedAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  jobId                String?
  job                  Job?            @relation(fields: [jobId], references: [id])
  evaluation           Evaluation?
  consentGiven         Boolean         @default(false)
  consentAt            DateTime?
  privacyPolicyVersion String?
  emailOptOut          Boolean         @default(false)
  emailLogs            EmailLog[]
}

model Evaluation {
  id             String    @id @default(cuid())
  score          Int
  reasoning      String
  pros           String    // JSON array stored as string
  cons           String    // JSON array stored as string
  promptSnapshot String
  createdAt      DateTime  @default(now())
  candidateId    String    @unique
  candidate      Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("RECRUITER")
  createdAt DateTime @default(now())
  jobs      Job[]
}

/// Key-value store for admin-controlled global settings (e.g. RETENTION_DAYS)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Email template stored in the database and editable by admins
model EmailTemplate {
  type      EmailType @id
  subject   String
  body      String // HTML; supports {{candidateName}}, {{jobTitle}}, {{companyName}}, {{statusPageUrl}}, {{retentionDate}}
  updatedAt DateTime  @updatedAt
}

/// Audit log of every outbound candidate email
model EmailLog {
  id          String    @id @default(cuid())
  candidateId String
  type        EmailType
  sentAt      DateTime  @default(now())
  resendId    String? // Resend delivery ID for tracking
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

enum CandidateStatus {
  APPLIED
  ANALYZING
  SHORTLISTED
  ACCEPTED
  REJECTED
}

enum EmailType {
  APPLIED
  SHORTLISTED
  REJECTED
  ACCEPTED
  DATA_RETENTION_WARNING
}
